# إنشاء ملف .gitignore
echo "__pycache__/" >> .gitignore
echo "*.pyc" >> .gitignore
echo "bot_database.db" >> .gitignore
echo ".env" >> .gitignore

# إضافة .gitignore إلى git
git add .gitignore
git commit -m "إضافة .gitignore لمنع رفع الملفات المؤقتة"
git push origin master

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
